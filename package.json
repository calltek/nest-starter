{
    "name": "nest-starter",
    "version": "0.1.0",
    "description": "NestJS + Bun + Prisma starter",
    "main": "dist/main.js",
    "private": true,
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "bun nest build",
        "format": "biome format --write src test",
        "start:migrate": "prisma migrate deploy && bun dist/main.js",
        "migrate": "prisma migrate deploy",
        "docker:dev": "docker-compose -f docker.development.yml up -d",
        "dev": "bun nest start --watch",
        "debug": "bun nest start --debug --watch",
        "lint": "biome check --write src test",
        "check": "biome check src test",
        "test": "bun test",
        "test:watch": "bun test --watch",
        "test:cov": "bun test --coverage",
        "generate": "prisma generate",
        "db:import": "f() { export $(grep -v '^#' .env | xargs); [ -z \"$1\" ] && echo 'Uso: npm run db:import -- /ruta/dump.sql.gz' && exit 1; PGPASSWORD=$DB_PASSWORD psql -h localhost -p $DB_PORT -U postgres -c \"SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname = '$DB_NAME' AND pid <> pg_backend_pid();\"; PGPASSWORD=$DB_PASSWORD psql -h localhost -p $DB_PORT -U postgres -c \"DROP DATABASE IF EXISTS $DB_NAME;\"; PGPASSWORD=$DB_PASSWORD psql -h localhost -p $DB_PORT -U postgres -c \"CREATE DATABASE $DB_NAME;\"; gunzip -c \"$1\" | PGPASSWORD=$DB_PASSWORD pg_restore -h localhost -p $DB_PORT -U postgres -d $DB_NAME --no-owner --role=postgres; }; f"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@anthropic-ai/sdk": "^0.93.0",
        "@keyv/redis": "^5.1.6",
        "@nestjs/cache-manager": "^3.1.2",
        "@nestjs/common": "^11.1.19",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11.1.19",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/platform-express": "^11.1.19",
        "@nestjs/platform-socket.io": "^11.1.19",
        "@nestjs/schedule": "^6.1.3",
        "@nestjs/serve-static": "^5.0.5",
        "@nestjs/swagger": "^11.4.2",
        "@nestjs/websockets": "^11.1.19",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@sentry/cli": "^3.4.1",
        "@sentry/nestjs": "^10.51.0",
        "@sentry/profiling-node": "^10.51.0",
        "bcrypt": "^6.0.0",
        "bullmq": "^5.76.5",
        "cache-manager": "^7.2.8",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dayjs": "^1.11.20",
        "dotenv": "^16.0.1",
        "figlet": "^1.11.0",
        "joi": "^18.2.1",
        "keyv": "^5.6.0",
        "nestjs-pino": "^4.6.1",
        "pino-http": "^8.2.0",
        "rxjs": "^7.8.1"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.14",
        "@nestjs/cli": "^11.0.21",
        "@nestjs/schematics": "^11.1.0",
        "@nestjs/testing": "^11.1.19",
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.7",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.13",
        "@types/figlet": "^1.7.0",
        "@types/node": "^25.6.0",
        "bun-types": "^1.3.13",
        "pino-pretty": "^13.1.3",
        "prisma": "^7.8.0",
        "rimraf": "^6.0.1",
        "typescript": "^5.9.3"
    }
}
