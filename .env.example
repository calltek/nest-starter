#####################################################################################################
# ******************************* TABLE OF CONTENTS *************************************************
#####################################################################################################
# - DOCKER
# - SERVER
# - DATABASE
# - AUTH
# - REDIS
# - VAULT
# - SENTRY


##########################################################################################
# ************************************* DOCKER *******************************************
##########################################################################################
# Used as prefix for container names and Traefik router IDs in production.
COMPOSE_PROJECT_NAME=app
# Public hostname for Traefik in production (e.g. api.example.com)
DOMAIN=


##########################################################################################
# ************************************* SERVER *******************************************
##########################################################################################
NODE_ENV=development
PORT=5050
VERBOSE=true
BASE_URL=http://localhost:5050
FRONTEND_URL=http://localhost:3000


############################################################################################
# ************************************ DATABASE ********************************************
############################################################################################
DB_NAME=app
DB_PORT=5432
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app?schema=public


########################################################################################
# *************************************** AUTH ****************************************
########################################################################################
JWT_SECRET_KEY=change-me-please


#########################################################################################
# ************************************* REDIS *******************************************
#########################################################################################
REDIS_HOST=localhost
REDIS_PORT=6380


#########################################################################################
# ************************************* VAULT *******************************************
#########################################################################################
# 32 bytes hex (64 chars) — usado para AES-GCM en pgcrypto
VAULT_MASTER_KEY=


##########################################################################################
# ************************************* SENTRY *******************************************
##########################################################################################
SENTRY_DSN=
SENTRY_ENABLED=false
